# Supabase public credentials (safe to expose in browser)
# Get these from: npx supabase status
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=<your-anon-key-from-supabase-status>

# Server-only Strava connect variables (do not expose to browser code)
STRAVA_WORKER_URL=http://localhost:8787
WORKER_SHARED_SECRET=<same-secret-as-workers-strava-dev-vars>
