{
  "name": "workout-dashboard",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "check": "turbo run check",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:reset": "npx supabase db reset",
    "db:types": "npx supabase gen types typescript --local > packages/shared/src/database.types.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "eslint": "^9.12.0",
    "globals": "^15.10.0",
    "prettier": "^3.3.3",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1"
  }
}
