{
  "name": "@brick/strava-worker",
  "private": true,
  "license": "MIT",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:scheduled": "wrangler dev --test-scheduled",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy": "wrangler deploy",
    "lint": "eslint .",
    "test": "vitest run",
    "test:scheduled": "node scripts/test-scheduled-sync.mjs",
    "webhook:view": "node scripts/strava-webhook-subscription.mjs view",
    "webhook:create": "node scripts/strava-webhook-subscription.mjs create",
    "webhook:delete": "node scripts/strava-webhook-subscription.mjs delete"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "@brick/shared": "workspace:*",
    "hono": "^4.10.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260508.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.81.0"
  }
}
