# Supabase project URL used by the worker for DB/API access.
SUPABASE_URL=
# Supabase secret key used by the worker for privileged DB writes.
SUPABASE_SECRET_KEY=
# Strava OAuth app client ID used for token exchange.
STRAVA_CLIENT_ID=
# Strava OAuth app client secret used for token exchange and refresh.
STRAVA_CLIENT_SECRET=
# Redirect URI registered in the Strava app for OAuth callbacks.
STRAVA_REDIRECT_URI=http://localhost:8787/strava/callback
# Verify token used by Strava when validating GET /strava/webhook callback ownership.
STRAVA_WEBHOOK_VERIFY_TOKEN=
# Shared signing secret used to validate X-Strava-Signature for POST /strava/webhook.
STRAVA_WEBHOOK_SIGNING_SECRET=
# Optional canonical callback URL used by webhook subscription helper scripts.
STRAVA_WEBHOOK_CALLBACK_URL=
# Base URL of the web app for post-auth redirects.
APP_URL=http://localhost:5173
# Shared signing secret between web app and worker for secure internal tokens.
WORKER_SHARED_SECRET=
# Minimum hours between automatic scheduled sync attempts per user.
STRAVA_SCHEDULED_SYNC_MIN_INTERVAL_HOURS=6
# Max users processed in a single scheduled sync run.
STRAVA_SCHEDULED_SYNC_LIMIT=25
